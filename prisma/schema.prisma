generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AttendanceStatus {
  ISDE
  EZAMIYYET
  MEZUNIYYET
  XESTE
  BAYRAM
  ICAZELI
  ISTIRAHET
  ISDE_DEYIL
  ISDE_XESARET
}

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

model AppUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  role         UserRole @default(VIEWER)
  isActive     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id                Int                @id @default(autoincrement())
  name              String
  department        String
  attendanceRecords AttendanceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique @db.Date
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @unique
  attendanceWorkLocations AttendanceWorkLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CarMaintenanceType {
  OIL_CHANGE
  INSURANCE
  INSPECTION
}

model CarMaintenanceRecord {
  id          Int                @id @default(autoincrement())
  carId       Int
  car         Car                @relation(fields: [carId], references: [id], onDelete: Cascade)
  type        CarMaintenanceType
  date        DateTime           @db.Date
  km          Int?
  oilBrand    String?
  oilQuantity Float?
  company     String?
  cost        Float?
  notes       String?

  createdAt DateTime @default(now())

  @@unique([carId, type, date])
  @@index([carId])
  @@index([type])
  @@index([date])
}

model Car {
  id           Int                @id @default(autoincrement())
  makeModel    String
  licensePlate String             @unique
  currentKm    Int?

  oilChangeDate       DateTime? @db.Date
  oilChangeKm         Int?
  oilBrand            String?
  oilQuantity         Float?
  oilChangeIntervalKm Int?

  insuranceDate           DateTime? @db.Date
  insuranceCompany        String?
  insuranceCost           Float?
  insuranceIntervalMonths Int?

  inspectionDate           DateTime? @db.Date
  inspectionIntervalMonths Int?

  records            AttendanceRecord[]
  maintenanceRecords CarMaintenanceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttendanceWorkLocation {
  id                 Int              @id @default(autoincrement())
  attendanceRecordId Int
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  locationId         Int
  location           Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([attendanceRecordId, locationId])
  @@index([locationId])
}

model StatusColor {
  id          Int              @id @default(autoincrement())
  status      AttendanceStatus @unique
  color       String
  displayText String           @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttendanceRecord {
  id              Int              @id @default(autoincrement())
  employeeId      Int
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime         @db.Date
  status          AttendanceStatus
  location        String?
  workLocations   AttendanceWorkLocation[]
  cookedHeadcount Int?
  cookedPaid      Boolean          @default(false)
  carDriven       Boolean          @default(false)
  carId           Int?
  car             Car?             @relation(fields: [carId], references: [id], onDelete: SetNull)
  note            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
}
